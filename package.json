{
  "name": "roca",
  "productName": "ROCA",
  "version": "1.0.0",
  "description": "ROCA — Results, Objectives, Challenges & Actions",
  "main": "dist/main/main/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.main.json && concurrently -k \"tsc -p tsconfig.main.json -w\" \"vite\" \"npx wait-on tcp:5173 && electron .\"",
    "build": "tsc -p tsconfig.main.json && vite build",
    "pack": "npm run build && electron-builder --mac --dir",
    "install-app": "npm run pack && rm -rf /Applications/ROCA.app && cp -R release/mac-arm64/ROCA.app /Applications/ROCA.app && echo '✅ ROCA installed to /Applications' && open /Applications/ROCA.app",
    "start": "electron .",
    "mobile:dev": "vite --config vite.mobile.config.ts",
    "mobile:build": "vite build --config vite.mobile.config.ts",
    "build:all": "npm run build && npm run mobile:build",
    "ios": "npm run mobile:build && npx cap sync ios && npx cap open ios",
    "rebuild": "electron-rebuild -f -w better-sqlite3 node-pty",
    "postinstall": "electron-rebuild -f -w better-sqlite3 node-pty"
  },
  "dependencies": {
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@xterm/addon-webgl": "^0.19.0",
    "better-sqlite3": "^11.7.0",
    "docx-preview": "^0.3.7",
    "exceljs": "^4.4.0",
    "mammoth": "^1.12.0",
    "node-pty": "^1.0.0",
    "recharts": "^3.8.0",
    "ws": "^8.20.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
